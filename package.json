{
  "name": "saga-dark",
  "displayName": "SAGA Dark",
  "description": "A dark VS Code theme built from the MIT-licensed SAGA palette.",
  "version": "0.1.4",
  "publisher": "oldjobobo",
  "icon": "icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/OldJobobo/saga-vscode-theme.git"
  },
  "homepage": "https://github.com/OldJobobo/saga-vscode-theme#readme",
  "bugs": {
    "url": "https://github.com/OldJobobo/saga-vscode-theme/issues"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Themes"
  ],
  "keywords": [
    "theme",
    "color-theme",
    "dark-theme",
    "saga",
    "pastel"
  ],
  "scripts": {
    "package": "vsce package --no-yarn --no-dependencies",
    "version:patch": "npm version patch",
    "version:minor": "npm version minor",
    "version:major": "npm version major",
    "release:patch": "npm version patch && vsce package --no-yarn --no-dependencies",
    "release:minor": "npm version minor && vsce package --no-yarn --no-dependencies",
    "release:major": "npm version major && vsce package --no-yarn --no-dependencies",
    "publish:smart": "bash ./scripts/publish-smart.sh",
    "publish:smart:minor": "bash ./scripts/publish-smart.sh minor",
    "publish:smart:major": "bash ./scripts/publish-smart.sh major",
    "pub": "bash ./scripts/publish-smart.sh",
    "pubm": "bash ./scripts/publish-smart.sh minor",
    "pubM": "bash ./scripts/publish-smart.sh major"
  },
  "contributes": {
    "themes": [
      {
        "label": "SAGA Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/saga-palette-color-theme.json",
        "semanticHighlighting": true
      }
    ]
  }
}
